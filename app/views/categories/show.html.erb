<p style="color: green"><%= notice %></p>

<%= render @category %> 

<div>
  <%= link_to "Edit this category", edit_category_path(@category) %> |
  <%= link_to "Back to categories", categories_path %>
  <div>
    <%= link_to "New Journal Entry for this Category", new_journal_entry_path(category_id: @category.id) %>
  </div>
  <div>
    <%= link_to "View all Journal Entries for this Category", journal_entries_path(category_id: @category.id) %>
  </div>

  <%= button_to "Destroy this category", @category, method: :delete %>
</div>
