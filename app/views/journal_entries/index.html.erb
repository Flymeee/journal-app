<p style="color: green"><%= notice %></p>

<% content_for :title, "Journal entries" %>

<h1>Journal entries</h1>

<%# app/views/journal_entries/index.html.erb %>

<table>
  <thead>
    <tr>
      <th>Title</th>
      <th>Content</th>
      <th>User</th>
      <th>Category</th>
      <th colspan="3"></th>
    </tr>
  </thead>

  <tbody>
    <% @journal_entries.each do |journal_entry| %>
      <tr>
        <td><%= journal_entry.title %></td>
        <td><%= journal_entry.content %></td>
        <td><%= journal_entry.user.email %></td>
        <td><%= journal_entry.category&.name %></td>
        <td><%= link_to "Show", journal_entry %></td>
        <td><%= link_to "Edit", edit_journal_entry_path(journal_entry) %></td>
        <td><%= link_to "Destroy", journal_entry, data: { "turbo-method": :delete, turbo_confirm: "Are you sure?" } %></td>
      </tr>
    <% end %>
  </tbody>
</table>

<br> <%# Added a <br> for spacing if you like %>

<%= link_to "New journal entry", new_journal_entry_path %>